{
    "default_paths": [
        "~/dev",
        "~/Projects",
        "~/repos",
        "~/workspace",
        "~/src",
        "~/Documents",
        "~/Desktop",
        "~/Downloads"
    ],
    "system_paths": [
        "/usr/local/lib/node_modules",
        "/opt/homebrew/lib/node_modules",
        "/opt/homebrew/Cellar",
        "/usr/local/Cellar",
        "~/.local/lib/python*/site-packages",
        "/opt/homebrew/lib/python*/site-packages",
        "/usr/local/lib/python*/site-packages",
        "/Library/Frameworks/Python.framework",
        "~/Library/Python/*/lib/python/site-packages",
        "~/.pyenv/versions/*/lib/python*/site-packages",
        "~/.conda/envs/*/lib/python*/site-packages",
        "~/miniconda3/lib/python*/site-packages",
        "~/anaconda3/lib/python*/site-packages",
        "~/.npm",
        "~/.nvm/versions/node/*/lib/node_modules",
        "~/.volta/tools/image/node/*/lib/node_modules",
        "~/.pnpm-store",
        "~/.bun/install/global",
        "~/Library/pnpm/global"
    ],
    "compromised": {
        "python": {
            "litellm": ["~1.82.8"]
        },
        "npm": {
            "axios": ["~1.14.1", "~0.30.4"]
        }
    }
}
